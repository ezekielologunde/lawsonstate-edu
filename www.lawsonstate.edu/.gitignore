# ──────────────────────────────────────────────────────────────
# Old live-site static mirror (saveweb2zip scrape) is reference
# material only — NOT versioned. Ignore everything at this repo
# root, then re-include just the monorepo project below. This
# keeps ~400k scraped HTML/asset files out of git history.
# ──────────────────────────────────────────────────────────────
/*

# Re-include the actual project
!/.gitignore
!/.npmrc
!/.vercelignore
!/package.json
!/package-lock.json
!/turbo.json
!/apps/
!/packages/
!/supabase/

# Keep deps/build/secrets out even inside re-included directories
node_modules/
.next/
.turbo/
.vercel/
.expo/
.env
.env.local
.env.*.local
